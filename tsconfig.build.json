{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "index.ts",
    "utils/**/*.ts",
    "ethereum-indexer/**/*.ts"
  ],
  "exclude": ["tests/**/*", "dist/**/*", "node_modules/**/*"]
}
